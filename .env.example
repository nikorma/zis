# ============================================================
# Siviglia – Guida personale di Nikos
# Copia questo file in ".env" e inserisci le tue chiavi.
# NESSUNA di queste chiavi deve finire nel codice frontend:
# vengono lette SOLO dalle funzioni serverless in /api.
# ============================================================

# IA per "Chiedi alla guida" e generazione contenuti (usata da /api/ai)
OPENAI_API_KEY=

# Text-to-Speech con voce naturale (usata da /api/tts)
ELEVENLABS_API_KEY=

# Opzionali: solo se scegli Google Maps o Mapbox al posto di OpenStreetMap
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=

# Opzionali: sincronizzazione account (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Pannello amministrativo (SOLO sviluppo, cambiare in produzione)
ADMIN_PASSWORD=siviglia-dev-2026

# Limiti anti-abuso per /api/ai
AI_DAILY_TOKEN_LIMIT=100000
AI_MAX_REQUESTS_PER_HOUR=60
